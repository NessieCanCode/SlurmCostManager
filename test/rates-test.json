{
  "defaultRate": 0.02,
  "defaultGpuRate": 0.2,
  "historicalRates": {
    "2024-01": 0.015
  },
  "historicalGpuRates": {
    "2024-01": 0.15
  },
  "overrides": {
    "research": {
      "rate": 0.01,
      "gpuRate": 0.1
    },
    "education": {
      "discount": 0.5
    },
    "oit": {
      "rate": 0.02,
      "gpuRate": 0.2
    }
  },
  "allocations": {
    "oit": {
      "type": "postpaid",
      "billing_period": "monthly",
      "budget_su": null
    },
    "ucmerced": {
      "type": "prepaid",
      "budget_su": 1000000,
      "period": "annual",
      "start_date": "2025-01-01",
      "end_date": "2025-12-31",
      "carryover": false,
      "alerts": [80, 90, 100]
    }
  },
  "billing_defaults": {
    "type": "postpaid",
    "billing_period": "monthly",
    "payment_terms_days": 30
  },
  "billing_rules": [
    {
      "id": "no-charge-failed",
      "name": "Don't charge failed jobs (except OOM and timeout)",
      "enabled": true,
      "condition": {
        "field": "state",
        "operator": "in",
        "values": ["FAILED", "CANCELLED", "NODE_FAIL"]
      },
      "exclude_states": ["OUT_OF_MEMORY", "TIMEOUT"],
      "action": "no_charge",
      "description": "Failed jobs are not billed unless they failed due to OOM or timeout"
    },
    {
      "id": "no-charge-short",
      "name": "Don't charge jobs under 1 minute",
      "enabled": true,
      "condition": {
        "field": "elapsed_seconds",
        "operator": "less_than",
        "value": 60
      },
      "action": "no_charge",
      "description": "Very short jobs are likely setup failures and not charged"
    }
  ]
}
