{
  "defaultRate": 0.02,
  "defaultGpuRate": 0.2,
  "historicalRates": {
    "2024-01": 0.015
  },
  "historicalGpuRates": {
    "2024-01": 0.15
  },
  "overrides": {
    "research": {
      "rate": 0.01,
      "gpuRate": 0.1
    },
    "education": {
      "discount": 0.5
    },
    "special": {
      "rate": 0.025,
      "gpuRate": 0.25,
      "discount": 0.1
    }
  },
  "allocations": {
    "physics-lab": {
      "type": "prepaid",
      "budget_su": 500000,
      "period": "annual",
      "start_date": "2026-01-01",
      "end_date": "2026-12-31",
      "carryover": false,
      "alerts": [80, 90, 100]
    },
    "chem-dept": {
      "type": "postpaid",
      "billing_period": "monthly",
      "budget_su": null
    }
  },
  "billing_defaults": {
    "type": "postpaid",
    "billing_period": "monthly",
    "payment_terms_days": 30
  },
  "billing_rules": [
    {
      "id": "no-charge-failed",
      "name": "Don't charge failed jobs (except OOM and timeout)",
      "enabled": true,
      "condition": {
        "field": "state",
        "operator": "in",
        "values": ["FAILED", "CANCELLED", "NODE_FAIL"]
      },
      "exclude_states": ["OUT_OF_MEMORY", "TIMEOUT"],
      "action": "no_charge",
      "description": "Failed jobs are not billed unless they failed due to OOM or timeout (user's fault)"
    },
    {
      "id": "no-charge-short",
      "name": "Don't charge jobs under 1 minute",
      "enabled": true,
      "condition": {
        "field": "elapsed_seconds",
        "operator": "less_than",
        "value": 60
      },
      "action": "no_charge",
      "description": "Very short jobs are likely setup failures and not charged"
    },
    {
      "id": "discount-debug",
      "name": "50% discount for debug partition",
      "enabled": false,
      "condition": {
        "field": "partition",
        "operator": "equals",
        "value": "debug"
      },
      "action": "discount",
      "discount_percent": 50,
      "description": "Debug partition runs at half rate"
    },
    {
      "id": "free-viz",
      "name": "Visualization partition is free",
      "enabled": false,
      "condition": {
        "field": "partition",
        "operator": "equals",
        "value": "viz"
      },
      "action": "no_charge",
      "description": "Visualization partition is not billed"
    },
    {
      "id": "cap-oom",
      "name": "Cap OOM jobs at requested time",
      "enabled": false,
      "condition": {
        "field": "state",
        "operator": "equals",
        "value": "OUT_OF_MEMORY"
      },
      "action": "charge_requested_time",
      "description": "OOM jobs are charged for the time requested, not wall time"
    }
  ]
}
